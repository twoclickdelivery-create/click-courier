{
  "expo": {
    "name": "CLICK Курьер",
    "slug": "click-courier",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "clickcourier",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#111111"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ru.clickdelivery.courier",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "CLICK использует ваше местоположение для определения адреса доставки и отображения вас на карте.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "CLICK использует ваше местоположение в фоновом режиме для отслеживания доставки заказов.",
        "NSCameraUsageDescription": "CLICK использует камеру для фото подтверждения доставки.",
        "NSPhotoLibraryUsageDescription": "CLICK использует фото для подтверждения доставки заказа.",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "ru.clickdelivery.courier",
      "versionCode": 1,
      "newArchEnabled": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.VIBRATE",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "CLICK использует ваше местоположение для доставки заказов."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "CLICK запрашивает доступ к фото для подтверждения доставки."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "1f1402e9-6c10-4e10-8aa3-96483319f423"
      }
    }
  }
}
